# https://dart.dev/guides/libraries/private-files
# Created by `dart pub`
.dart_tool/

# FVM (Flutter Version Management)
# Configuration is in .fvmrc, everything in .fvm/ is generated by `fvm install`
.fvm/

# Avoid committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock

# =============================================================================
# IMPORTANT: headers/ directory IS committed (not ignored)
# =============================================================================
# Headers are committed for:
#   - Transparency: See exactly what was used to generate bindings
#   - Reproducibility: Compare with previous versions
#   - Security audit: Review what functions are being bound
#   - CI: Regenerate bindings without building liboqs from source

# IDE files
.idea/
*.iml
*.ipr
*.iws
# .vscode/ is committed for FVM settings

# Flutter metadata
.metadata

# Flutter plugin generated files (regenerated by flutter)
ios/Flutter/
ios/Runner/
macos/Flutter/

# macOS generated
macos/*.xcworkspace/

# Miscellaneous
.DS_Store
*.log

# =============================================================================
# IMPORTANT: Native libraries are NOT ignored
# =============================================================================
# These directories contain pre-built liboqs binaries committed by CI:
#   bin/                          - Server/CLI (Linux, macOS, Windows)
#   ios/Frameworks/               - iOS XCFramework
#   android/src/main/jniLibs/     - Android shared libraries
#   macos/Libraries/              - macOS Flutter